{
  "name": "k2gl/slsa-provenance",
  "description": "Faithful, typed PHP implementation of the SLSA Provenance v1 and v0.2 predicates, built on k2gl/in-toto-attestation.",
  "homepage": "https://github.com/k2gl/slsa-provenance",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "slsa",
    "provenance",
    "in-toto",
    "attestation",
    "supply-chain",
    "sigstore",
    "dsse",
    "build"
  ],
  "authors": [
    {
      "name": "Nickolay Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/slsa-provenance/issues",
    "source": "https://github.com/k2gl/slsa-provenance"
  },
  "require": {
    "php": ">=8.1",
    "k2gl/in-toto-attestation": "^1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11|^12",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.64",
    "k2gl/phpunit-fluent-assertions": "^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\Slsa\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\Slsa\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
